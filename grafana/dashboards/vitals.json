      "from": "now-30d",
      "to": "now"
    },
    "templating": {
      "list": [
        {
          "name": "user",
          "type": "query",
          "datasource": "TimescaleDB",
          "query": "SELECT id AS __value, display_name AS __text FROM users ORDER BY display_name",
          "refresh": 1,
          "current": {},
          "label": "Athlete"
        },
        {
          "name": "datasource",
          "type": "datasource",
          "query": "postgres",
          "current": {
            "text": "TimescaleDB",
            "value": "TimescaleDB"
          },
          "label": "Data Source"
        },
        {
          "name": "tz",
          "label": "Timezone",
          "type": "custom",
          "query": "Australia/Sydney",
          "current": {
            "text": "Australia/Sydney",
            "value": "Australia/Sydney",
            "selected": true
          },
          "options": [
            {
              "text": "Australia/Sydney",
              "value": "Australia/Sydney",
              "selected": true
