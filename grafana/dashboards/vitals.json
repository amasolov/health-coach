      {
        "id": 1,
        "title": "Resting Heart Rate",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 0
        },
        "datasource": "$datasource",
        "targets": [
          {
            "refId": "A",
            "rawSql": "SELECT time, resting_hr AS \"Resting HR\" FROM vitals WHERE user_id = $user AND resting_hr IS NOT NULL AND $__timeFilter(time) ORDER BY time",
            "format": "time_series"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "fixed",
              "fixedColor": "red"
            },
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10,
              "showPoints": "always",
              "pointSize": 4
            },
            "unit": "bpm"
          }
        },
        "links": [
          {
            "title": "View PMC",
            "url": "/d/health-pmc/?var-user=$user&${__url_time_range}"
          }
        ]
      },
