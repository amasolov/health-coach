      {
        "id": 30,
        "title": "Weekly Training Volume (hours)",
        "type": "barchart",
        "gridPos": {
          "x": 0,
          "y": 13,
          "w": 12,
          "h": 8
        },
        "datasource": "$datasource",
        "targets": [
          {
            "refId": "A",
            "rawSql": "SET LOCAL timezone = '$tz'; SELECT time_bucket('1 week', time) AS time, ROUND(SUM(duration_s) / 3600.0, 1) AS \"Hours\" FROM activities WHERE user_id = $user AND $__timeFilter(time) GROUP BY 1 ORDER BY 1",
            "format": "time_series"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "fixed",
              "fixedColor": "blue"
            },
            "custom": {
              "fillOpacity": 80
            }
          }
        },
        "links": [
          {
            "title": "View Activities",
            "url": "/d/health-activities/?var-user=$user&${__url_time_range}"
          }
        ]
      },
      {
        "id": 31,
        "title": "CTL / ATL / TSB (mini)",
        "type": "timeseries",
        "gridPos": {
          "x": 12,
          "y": 13,
          "w": 12,
          "h": 8
        },
        "datasource": "$datasource",
        "targets": [
          {
            "refId": "A",
            "rawSql": "SELECT time, ctl AS \"CTL\", atl AS \"ATL\", tsb AS \"TSB\" FROM training_load WHERE user_id = $user AND source = 'calculated' AND $__timeFilter(time) ORDER BY time",
            "format": "time_series"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "lineWidth": 1,
              "fillOpacity": 0,
              "showPoints": "never"
            }
          },
          "overrides": [
            {
              "matcher": {
                "id": "byName",
                "options": "CTL"
              },
              "properties": [
                {
                  "id": "color",
                  "value": {
                    "mode": "fixed",
                    "fixedColor": "blue"
                  }
                }
              ]
            },
            {
              "matcher": {
                "id": "byName",
                "options": "ATL"
              },
              "properties": [
                {
                  "id": "color",
                  "value": {
                    "mode": "fixed",
                    "fixedColor": "red"
                  }
                }
              ]
            },
            {
              "matcher": {
                "id": "byName",
                "options": "TSB"
              },
              "properties": [
                {
                  "id": "color",
                  "value": {
                    "mode": "fixed",
                    "fixedColor": "yellow"
                  }
                },
                {
                  "id": "custom.fillOpacity",
                  "value": 10
                }
              ]
            }
          ]
        },
        "options": {
          "legend": {
            "displayMode": "list",
            "placement": "bottom"
          }
        },
        "links": [
          {
            "title": "View PMC",
            "url": "/d/health-pmc/?var-user=$user&${__url_time_range}"
          }
        ]
      },
      {
        "id": 42,
        "title": "Weight",
        "description": "Current body weight with 8-week trend. Gradual changes are healthy \u2014 sudden swings may indicate hydration or measurement issues.",
        "type": "stat",
        "gridPos": {
          "x": 0,
          "y": 21,
          "w": 4,
          "h": 5
        },
        "datasource": "$datasource",
        "links": [
          {
            "title": "View Body Composition",
            "url": "/d/health-body/?var-user=$user&from=now-6M&to=now"
          }
        ],
        "targets": [
          {
            "refId": "A",
            "rawSql": "SET LOCAL timezone = '$tz'; SELECT time, weight_kg AS \"kg\" FROM body_composition WHERE user_id = $user AND weight_kg IS NOT NULL AND time >= NOW() - INTERVAL '8 weeks' ORDER BY time",
            "format": "time_series"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "decimals": 1,
            "color": {
              "mode": "fixed",
              "fixedColor": "#3274D9"
            }
          },
          "overrides": []
        },
        "options": {
          "reduceOptions": {
            "calcs": [
              "lastNotNull"
            ]
          },
          "colorMode": "background_solid",
          "graphMode": "area",
          "justifyMode": "center",
          "textMode": "auto"
        }
      },
      {
        "id": 43,
        "title": "Body Fat",
        "description": "Body fat percentage. For men: 6-13% athletic, 14-17% fit, 18-24% average. For women: 14-20% athletic, 21-24% fit, 25-31% average.",
        "type": "gauge",
        "gridPos": {
          "x": 4,
          "y": 21,
          "w": 4,
          "h": 5
        },
        "datasource": "$datasource",
        "links": [
