          "y": 13,
          "w": 12,
          "h": 8
        },
        "datasource": "$datasource",
        "targets": [
          {
            "refId": "A",
            "rawSql": "SELECT time, ctl AS \"CTL\", atl AS \"ATL\", tsb AS \"TSB\" FROM training_load WHERE user_id = $user AND source = 'calculated' AND $__timeFilter(time) ORDER BY time",
            "format": "time_series"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "lineWidth": 1,
              "fillOpacity": 0,
              "showPoints": "never"
