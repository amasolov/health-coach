          }
        ],
        "description": "How fast your fitness is changing per week. +3 to +5 is ideal. Above +7 risks burnout. Negative means detraining."
      },
      {
        "id": 21,
        "title": "Resting HR",
        "description": "Resting heart rate. Lower is better \u2014 shows cardiovascular fitness. A sudden rise may signal overtraining or illness.",
        "type": "gauge",
        "gridPos": {
          "x": 0,
          "y": 8,
          "w": 5,
          "h": 5
        },
        "datasource": "$datasource",
        "targets": [
          {
            "refId": "A",
            "rawSql": "SELECT resting_hr AS \"BPM\" FROM vitals WHERE user_id = $user AND resting_hr IS NOT NULL ORDER BY time DESC LIMIT 1",
            "format": "table"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "value": null,
