{
  "dashboard": {
    "title": "Athlete Home",
    "uid": "health-home",
    "tags": [
      "healthcoach"
    ],
    "timezone": "browser",
    "editable": true,
    "time": {
      "from": "now-30d",
      "to": "now"
    },
    "templating": {
      "list": [
        {
          "name": "user",
          "type": "query",
          "datasource": "TimescaleDB",
          "query": "SELECT id AS __value, display_name AS __text FROM users ORDER BY display_name",
          "refresh": 1,
          "current": {},
          "label": "Athlete"
        },
        {
          "name": "datasource",
          "type": "datasource",
          "query": "postgres",
          "current": {
            "text": "TimescaleDB",
            "value": "TimescaleDB"
          },
          "label": "Data Source"
        },
        {
          "name": "tz",
          "label": "Timezone",
          "type": "custom",
          "query": "Australia/Sydney",
          "current": {
            "text": "Australia/Sydney",
            "value": "Australia/Sydney",
            "selected": true
          },
          "options": [
            {
              "text": "Australia/Sydney",
              "value": "Australia/Sydney",
              "selected": true
            }
          ],
          "hide": 2
        }
      ]
    },
    "links": [
      {
        "title": "PMC",
        "url": "/d/health-pmc/?var-user=$user&${__url_time_range}",
        "type": "link",
        "icon": "bolt",
        "tooltip": "Performance Management Chart"
      },
      {
        "title": "Activities",
        "url": "/d/health-activities/?var-user=$user&${__url_time_range}",
        "type": "link",
        "icon": "play",
        "tooltip": "Activities Overview"
      },
      {
        "title": "Vitals",
        "url": "/d/health-vitals/?var-user=$user&${__url_time_range}",
        "type": "link",
        "icon": "heart",
        "tooltip": "Vitals & Recovery"
      },
      {
        "title": "Body Comp",
        "url": "/d/health-body/?var-user=$user&${__url_time_range}",
        "type": "link",
        "icon": "user",
        "tooltip": "Body Composition"
      },
      {
        "title": "Strength",
        "url": "/d/health-strength/?var-user=$user&${__url_time_range}",
        "type": "link",
        "icon": "fire",
        "tooltip": "Strength Training"
      }
    ],
    "panels": [
      {
        "id": 15,
        "title": "Today's Advice",
        "description": "Based on your current Form (TSB = Fitness minus Fatigue). This tells you whether your body is ready for hard training or needs rest.",
        "type": "stat",
        "gridPos": {
          "x": 0,
          "y": 0,
          "w": 24,
          "h": 3
        },
        "datasource": "$datasource",
        "targets": [
          {
            "refId": "A",
            "rawSql": "SELECT round(tsb::numeric, 1) AS \"TSB\" FROM training_load WHERE user_id = $user AND source = 'calculated' ORDER BY time DESC LIMIT 1",
            "format": "table"
          }
        ],
        "options": {
          "reduceOptions": {
            "calcs": [
              "lastNotNull"
            ],
            "fields": "",
            "values": false
          },
          "textMode": "value",
          "colorMode": "background_solid",
          "justifyMode": "center"
        },
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {
                "type": "range",
                "options": {
                  "from": -9999,
                  "to": -30,
                  "result": {
                    "text": "REST DAY \u2014 injury & illness risk",
                    "index": 0
                  }
                }
              },
              {
                "type": "range",
                "options": {
                  "from": -30,
                  "to": -10,
                  "result": {
                    "text": "EASY DAY \u2014 back off or recover",
                    "index": 1
                  }
                }
              },
              {
                "type": "range",
                "options": {
                  "from": -10,
                  "to": 5,
                  "result": {
                    "text": "TRAIN \u2014 good zone for hard work",
                    "index": 2
                  }
                }
              },
              {
                "type": "range",
                "options": {
                  "from": 5,
                  "to": 25,
                  "result": {
                    "text": "FRESH \u2014 ready for a big session",
                    "index": 3
                  }
                }
              },
              {
                "type": "range",
                "options": {
                  "from": 25,
                  "to": 9999,
                  "result": {
                    "text": "TOO FRESH \u2014 fitness fading, train!",
                    "index": 4
                  }
                }
              }
            ],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "value": null,
                  "color": "dark-red"
                },
                {
                  "value": -30,
                  "color": "dark-orange"
                },
                {
                  "value": -10,
                  "color": "#b5a20f"
                },
                {
                  "value": 5,
                  "color": "dark-green"
                },
                {
                  "value": 25,
                  "color": "dark-blue"
                }
              ]
            },
            "color": {
              "mode": "thresholds"
            }
          },
          "overrides": []
        }
      },
      {
        "id": 10,
        "title": "Fitness (CTL)",
        "type": "gauge",
        "gridPos": {
          "x": 0,
          "y": 3,
          "w": 6,
          "h": 5
        },
        "datasource": "$datasource",
        "targets": [
          {
            "refId": "A",
            "rawSql": "SELECT ctl AS \"CTL (Fitness)\" FROM training_load WHERE user_id = $user AND source = 'calculated' ORDER BY time DESC LIMIT 1",
            "format": "table"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 80,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "value": null,
                  "color": "red"
                },
                {
                  "value": 15,
                  "color": "orange"
                },
                {
                  "value": 25,
                  "color": "yellow"
                },
                {
                  "value": 40,
                  "color": "green"
                },
                {
                  "value": 60,
                  "color": "blue"
                }
              ]
            },
            "color": {
              "mode": "thresholds"
            }
          }
        },
        "options": {
          "reduceOptions": {
            "calcs": [
              "lastNotNull"
            ],
            "fields": "",
            "values": false
          },
          "showThresholdLabels": false,
          "showThresholdMarkers": true,
          "orientation": "auto"
        },
        "links": [
          {
            "title": "View PMC",
            "url": "/d/health-pmc/?var-user=$user&${__url_time_range}"
          }
        ],
        "description": "Long-term training load (42-day average). Higher = fitter. Builds slowly over weeks of consistent training."
      },
      {
