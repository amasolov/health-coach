      {
        "id": 60,
        "title": "Action Items",
        "description": "Personalized recommendations based on your current recovery, training load, and muscle coverage. Updated every refresh.",
        "type": "table",
        "gridPos": {
          "x": 0,
          "y": 21,
          "w": 24,
          "h": 7
        },
        "datasource": "$datasource",
        "targets": [
          {
            "refId": "A",
            "rawSql": "SET LOCAL timezone = '$tz';\n\nWITH\nrecovery AS (\n  SELECT\n    (SELECT resting_hr FROM vitals WHERE user_id = $user AND resting_hr IS NOT NULL ORDER BY time DESC LIMIT 1) AS rhr,\n    (SELECT hrv_ms FROM vitals WHERE user_id = $user AND hrv_ms IS NOT NULL ORDER BY time DESC LIMIT 1) AS hrv,\n    (SELECT sleep_score FROM vitals WHERE user_id = $user AND sleep_score IS NOT NULL ORDER BY time DESC LIMIT 1) AS sleep,\n    (SELECT body_battery_high FROM vitals WHERE user_id = $user AND body_battery_high IS NOT NULL ORDER BY time DESC LIMIT 1) AS battery,\n    (SELECT stress_avg FROM vitals WHERE user_id = $user AND stress_avg IS NOT NULL ORDER BY time DESC LIMIT 1) AS stress\n),\nload AS (\n  SELECT\n    (SELECT tsb FROM training_load WHERE user_id = $user AND source = 'calculated' ORDER BY time DESC LIMIT 1) AS tsb,\n    (SELECT ramp FROM training_load WHERE user_id = $user AND source = 'calculated' ORDER BY time DESC LIMIT 1) AS ramp,\n    (SELECT COALESCE(ROUND(SUM(tss)::numeric, 0), 0) FROM activities WHERE user_id = $user AND time >= NOW() - INTERVAL '7 days') AS tss_7d,\n    (SELECT ROUND(AVG(weekly_tss)::numeric, 0) FROM (\n       SELECT SUM(tss) AS weekly_tss FROM activities WHERE user_id = $user AND time >= NOW() - INTERVAL '28 days'\n       GROUP BY time_bucket('1 week', time)) w) AS avg_tss_4w\n),\nneglected AS (\n  SELECT COUNT(*) AS cnt,\n    string_agg(\n      CASE muscle_group\n        WHEN 'upper_back' THEN 'Upper Back'\n        WHEN 'abdominals' THEN 'Core'\n        WHEN 'quadriceps' THEN 'Quads'\n        WHEN 'hamstrings' THEN 'Hamstrings'\n        ELSE INITCAP(REPLACE(muscle_group, '_', ' '))\n      END, ', ' ORDER BY MAX(time)\n    ) AS muscles\n  FROM (\n    SELECT muscle_group, MAX(time) AS time\n    FROM strength_sets\n    WHERE user_id = $user AND set_type = 'normal' AND muscle_group != '' AND muscle_group NOT IN ('cardio','full_body','other')\n    GROUP BY muscle_group\n    HAVING MAX(time) < NOW() - INTERVAL '7 days'\n  ) sub\n),\nfreq AS (\n  SELECT COUNT(DISTINCT time::date) AS sessions_this_week\n  FROM activities WHERE user_id = $user AND time >= date_trunc('week', NOW())\n),\nitems AS (\n  -- Recovery-based items\n  SELECT 1 AS priority, 'Recovery' AS \"Category\",\n    CASE\n      WHEN battery < 25 THEN 'Rest day \u2014 Body Battery is depleted (' || battery || '/100)'\n      WHEN stress > 50 THEN 'Take it easy \u2014 stress is very high (' || stress || ')'\n      WHEN sleep < 60 THEN 'Light session only \u2014 poor sleep last night (' || sleep || '/100)'\n      WHEN hrv < 25 THEN 'Rest or easy session \u2014 HRV is critically low (' || hrv || ' ms)'\n      WHEN battery < 50 AND stress > 35 THEN 'Easy day \u2014 low energy + elevated stress'\n      ELSE NULL\n    END AS \"Action\"\n  FROM recovery\n\n  UNION ALL\n\n  -- Training load items\n  SELECT 2, 'Training Load',\n    CASE\n      WHEN tsb < -30 THEN 'Mandatory rest \u2014 Form is ' || ROUND(tsb::numeric, 0) || ' (injury/illness risk zone)'\n      WHEN tsb < -10 THEN 'Back off \u2014 overreaching (Form = ' || ROUND(tsb::numeric, 0) || ')'\n      WHEN ramp > 7 THEN 'Slow down \u2014 ramp rate ' || ROUND(ramp::numeric, 1) || '/week risks burnout'\n      WHEN tss_7d > avg_tss_4w * 1.3 AND avg_tss_4w > 0 THEN 'This week''s load (' || tss_7d || ' TSS) is ' || ROUND(((tss_7d::float / avg_tss_4w - 1) * 100)::numeric, 0) || '% above your 4-week average \u2014 ease off'\n      WHEN tsb > 25 THEN 'Fitness fading \u2014 TSB is ' || ROUND(tsb::numeric, 0) || ', time to train harder'\n      WHEN ramp < 0 THEN 'You''re detraining (ramp = ' || ROUND(ramp::numeric, 1) || ') \u2014 increase load gradually'\n      ELSE NULL\n    END\n  FROM load\n\n  UNION ALL\n\n  -- Volume target\n  SELECT 3, 'Weekly Volume',\n    CASE\n      WHEN sessions_this_week < 1 AND EXTRACT(DOW FROM NOW()) >= 3 THEN 'No sessions yet this week \u2014 schedule a workout today'\n      WHEN sessions_this_week < 2 AND EXTRACT(DOW FROM NOW()) >= 5 THEN 'Only ' || sessions_this_week || ' session this week \u2014 try to fit one more in'\n      ELSE NULL\n    END\n  FROM freq\n\n  UNION ALL\n\n  -- Neglected muscles\n  SELECT 4, 'Muscle Balance',\n    CASE\n      WHEN cnt > 0 THEN 'Train these neglected muscles: ' || muscles || ' (' || cnt || ' groups not hit in 7+ days)'\n      ELSE NULL\n    END\n  FROM neglected\n\n  UNION ALL\n\n  -- Positive reinforcement when everything is good\n  SELECT 5, 'Status',\n    CASE\n      WHEN battery >= 75 AND sleep >= 80 AND stress < 25\n           AND tsb BETWEEN -10 AND 15 AND ramp BETWEEN 0 AND 5\n      THEN 'All systems green \u2014 great day for a quality session!'\n      ELSE NULL\n    END\n  FROM recovery, load\n)\nSELECT \"Category\", \"Action\" FROM items WHERE \"Action\" IS NOT NULL ORDER BY priority",
            "format": "table"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "align": "left"
            }
          },
          "overrides": [
            {
              "matcher": {
                "id": "byName",
                "options": "Category"
              },
              "properties": [
                {
                  "id": "custom.width",
                  "value": 140
                },
                {
                  "id": "custom.displayMode",
                  "value": "color-background-solid"
                },
                {
                  "id": "mappings",
                  "value": [
                    {
                      "type": "value",
                      "options": {
                        "Recovery": {
                          "color": "red",
                          "index": 0
                        }
                      }
                    },
                    {
                      "type": "value",
                      "options": {
                        "Training Load": {
                          "color": "orange",
                          "index": 1
                        }
                      }
                    },
                    {
                      "type": "value",
                      "options": {
                        "Weekly Volume": {
                          "color": "yellow",
                          "index": 2
                        }
                      }
                    },
                    {
                      "type": "value",
                      "options": {
                        "Muscle Balance": {
                          "color": "blue",
                          "index": 3
                        }
                      }
                    },
                    {
                      "type": "value",
                      "options": {
                        "Status": {
                          "color": "green",
                          "index": 4
                        }
                      }
                    }
                  ]
                }
              ]
            },
            {
              "matcher": {
                "id": "byName",
                "options": "Action"
              },
              "properties": [
                {
                  "id": "custom.displayMode",
                  "value": "auto"
                }
              ]
            }
          ]
        },
        "options": {
          "showHeader": true,
          "footer": {
            "show": false
          }
