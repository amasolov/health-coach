      {
        "id": 30,
        "title": "Weekly Training Load",
        "type": "timeseries",
        "gridPos": {
          "x": 0,
          "y": 13,
          "w": 12,
          "h": 8
        },
        "datasource": "$datasource",
        "targets": [
          {
            "refId": "A",
            "rawSql": "SET LOCAL timezone = '$tz'; SELECT time_bucket('1 week', time) AS time, ROUND(SUM(tss)::numeric, 0) AS \"TSS\" FROM activities WHERE user_id = $user AND tss IS NOT NULL AND $__timeFilter(time) GROUP BY 1 ORDER BY 1",
            "format": "time_series"
          },
          {
            "refId": "B",
            "rawSql": "SET LOCAL timezone = '$tz'; SELECT time_bucket('1 week', time) AS time, ROUND(SUM(duration_s) / 3600.0, 1) AS \"Hours\" FROM activities WHERE user_id = $user AND $__timeFilter(time) GROUP BY 1 ORDER BY 1",
            "format": "time_series"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            }
          },
          "overrides": [
            {
              "matcher": {
                "id": "byName",
                "options": "TSS"
              },
              "properties": [
                {
                  "id": "color",
                  "value": {
                    "mode": "fixed",
                    "fixedColor": "orange"
                  }
                },
                {
                  "id": "custom.axisPlacement",
                  "value": "left"
                },
                {
                  "id": "custom.axisLabel",
                  "value": "TSS"
                }
              ]
            },
            {
              "matcher": {
                "id": "byName",
                "options": "Hours"
              },
              "properties": [
                {
                  "id": "color",
                  "value": {
                    "mode": "fixed",
                    "fixedColor": "#3274D9"
                  }
                },
                {
                  "id": "custom.axisPlacement",
                  "value": "right"
                },
                {
                  "id": "custom.axisLabel",
                  "value": "Hours"
                },
                {
                  "id": "custom.drawStyle",
                  "value": "line"
                },
                {
                  "id": "custom.lineWidth",
                  "value": 2
                },
                {
                  "id": "custom.fillOpacity",
                  "value": 0
                },
                {
                  "id": "custom.showPoints",
                  "value": "always"
                },
                {
                  "id": "custom.pointSize",
                  "value": 6
                }
              ]
            }
          ]
        },
        "links": [
          {
            "title": "View Activities",
            "url": "/d/health-activities/?var-user=$user&${__url_time_range}"
          }
        ],
        "description": "Weekly Training Stress Score (TSS) and training hours. TSS accounts for both duration and intensity \u2014 it is more meaningful than hours alone. Aim for consistent weekly TSS without big spikes (10% rule).",
        "options": {
          "legend": {
            "displayMode": "list",
            "placement": "bottom",
            "calcs": [
              "lastNotNull",
              "mean"
            ]
          },
          "tooltip": {
            "mode": "multi"
          }
        }
      },
      {
        "id": 31,
        "title": "CTL / ATL / TSB (mini)",
