        "datasource": "$datasource",
        "targets": [
          {
            "refId": "A",
            "rawSql": "SELECT atl AS \"ATL (Fatigue)\" FROM training_load WHERE user_id = $user AND source = 'calculated' ORDER BY time DESC LIMIT 1",
