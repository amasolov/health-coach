        "datasource": "$datasource",
        "targets": [
          {
            "refId": "A",
            "rawSql": "SELECT tsb AS \"TSB (Form)\" FROM training_load WHERE user_id = $user AND source = 'calculated' ORDER BY time DESC LIMIT 1",
            "format": "table"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "value": null,
                  "color": "dark-red"
                },
                {
                  "value": -30,
                  "color": "red"
                },
                {
                  "value": -10,
                  "color": "orange"
                },
                {
                  "value": 0,
                  "color": "yellow"
                },
                {
                  "value": 5,
                  "color": "green"
                },
                {
                  "value": 25,
                  "color": "blue"
                }
              ]
            },
            "min": -40,
            "max": 40,
            "color": {
              "mode": "thresholds"
            }
