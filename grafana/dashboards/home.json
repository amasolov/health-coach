        "targets": [
          {
            "refId": "A",
            "rawSql": "SET LOCAL timezone = '$tz'; SELECT time::date AS \"Date\", activity_type AS \"Sport\", title AS \"Title\", ROUND(duration_s / 60.0) AS \"Min\", ROUND((distance_m / 1000.0)::numeric, 1) AS \"km\", avg_hr AS \"HR\", avg_power AS \"Power\", ROUND(tss::numeric, 0) AS \"TSS\" FROM activities WHERE user_id = $user AND $__timeFilter(time) ORDER BY time DESC LIMIT 15",
