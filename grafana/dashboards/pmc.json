{
  "dashboard": {
    "title": "Performance Management Chart",
    "uid": "health-pmc",
    "tags": [
      "health-tracker",
      "pmc"
    ],
    "timezone": "browser",
    "editable": true,
    "time": {
      "from": "now-12w",
      "to": "now+8w"
    },
    "templating": {
      "list": [
        {
          "name": "user",
          "type": "query",
          "datasource": "TimescaleDB",
          "query": "SELECT id AS __value, display_name AS __text FROM users ORDER BY display_name",
          "refresh": 1,
          "current": {},
          "label": "Athlete"
        },
        {
          "name": "datasource",
          "type": "datasource",
          "query": "postgres",
          "current": {
            "text": "TimescaleDB",
            "value": "TimescaleDB"
          },
          "label": "Data Source"
        }
      ]
    },
    "panels": [
      {
        "id": 10,
        "title": "",
        "type": "text",
        "gridPos": {
          "h": 6,
          "w": 16,
          "x": 0,
          "y": 0
        },
        "options": {
          "mode": "markdown",
          "content": "## How to read this chart\n\n| Metric | What it means | Think of it as\u2026 |\n|---|---|---|\n| **Fitness (CTL)** | Your long-term training load (42-day average). Higher = fitter. | How much your body is *used to* doing |\n| **Fatigue (ATL)** | Your short-term training load (7-day average). Higher = more tired. | How much you've done *recently* |\n| **Form (TSB)** | Fitness minus Fatigue. Shows how fresh or fatigued you are *right now*. | Your readiness to perform |\n\n**Key rule:** When Fatigue (red) rises far above Fitness (blue), you're accumulating risk. The yellow Form line going deeply negative means you're digging a hole \u2014 good for building fitness, dangerous if it stays there too long."
        }
      },
      {
        "id": 11,
        "title": "Today's Advice",
        "type": "stat",
        "gridPos": {
          "h": 6,
          "w": 8,
          "x": 16,
          "y": 0
        },
        "datasource": "$datasource",
        "targets": [
          {
            "refId": "A",
            "rawSql": "SELECT round(tsb::numeric, 1) AS \"TSB\" FROM training_load WHERE user_id = $user AND source = 'calculated' ORDER BY time DESC LIMIT 1",
            "format": "table"
          }
        ],
        "options": {
          "reduceOptions": {
            "calcs": [
              "lastNotNull"
            ]
          },
          "textMode": "value",
          "colorMode": "background_solid",
          "justifyMode": "center"
        },
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {
                "type": "range",
                "options": {
                  "from": -9999,
                  "to": -30,
                  "result": {
                    "text": "REST DAY\nInjury & illness risk",
                    "index": 0
                  }
                }
              },
              {
                "type": "range",
                "options": {
                  "from": -30,
                  "to": -10,
                  "result": {
                    "text": "EASY DAY\nOverreaching \u2014 back off",
                    "index": 1
                  }
                }
              },
              {
                "type": "range",
                "options": {
                  "from": -10,
                  "to": 5,
                  "result": {
                    "text": "TRAIN\nGood zone for hard work",
                    "index": 2
                  }
                }
              },
              {
                "type": "range",
                "options": {
                  "from": 5,
                  "to": 25,
                  "result": {
                    "text": "FRESH\nReady for a big session",
                    "index": 3
                  }
                }
              },
              {
                "type": "range",
                "options": {
                  "from": 25,
                  "to": 9999,
                  "result": {
                    "text": "TOO FRESH\nFitness fading \u2014 train!",
                    "index": 4
                  }
                }
              }
            ],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "value": null,
                  "color": "dark-red"
                },
                {
                  "value": -30,
                  "color": "dark-orange"
                },
                {
                  "value": -10,
                  "color": "#b5a20f"
                },
                {
                  "value": 5,
                  "color": "dark-green"
                },
                {
                  "value": 25,
                  "color": "dark-blue"
                }
              ]
            },
            "color": {
              "mode": "thresholds"
            }
          }
        }
      },
      {
        "id": 1,
        "title": "Performance Management Chart (CTL / ATL / TSB)",
        "description": "The main chart. Blue = long-term fitness, Red = recent fatigue, Yellow = freshness/form. Dashed lines show projections based on your average training load.",
        "type": "timeseries",
        "gridPos": {
          "h": 14,
          "w": 24,
          "x": 0,
          "y": 6
        },
        "datasource": "$datasource",
        "targets": [
          {
            "refId": "A",
            "rawSql": "SELECT time, ctl AS \"Fitness (CTL)\", atl AS \"Fatigue (ATL)\", tsb AS \"Form (TSB)\" FROM training_load WHERE user_id = $user AND source = 'calculated' AND $__timeFilter(time) ORDER BY time",
            "format": "time_series"
          },
          {
            "refId": "B",
            "rawSql": "SELECT time, ctl AS \"CTL (projected)\", atl AS \"ATL (projected)\", tsb AS \"TSB (projected)\" FROM training_load WHERE user_id = $user AND source = 'projected' AND $__timeFilter(time) ORDER BY time",
            "format": "time_series"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 0,
              "showPoints": "never",
              "axisLabel": ""
            },
            "unit": "none",
            "decimals": 1
          },
          "overrides": [
            {
              "matcher": {
                "id": "byName",
                "options": "Fitness (CTL)"
              },
              "properties": [
                {
                  "id": "color",
                  "value": {
                    "mode": "fixed",
                    "fixedColor": "blue"
                  }
                },
                {
                  "id": "custom.lineWidth",
                  "value": 3
                }
              ]
            },
            {
              "matcher": {
                "id": "byName",
                "options": "Fatigue (ATL)"
              },
              "properties": [
                {
                  "id": "color",
                  "value": {
                    "mode": "fixed",
                    "fixedColor": "red"
                  }
                }
              ]
            },
            {
              "matcher": {
                "id": "byName",
                "options": "Form (TSB)"
              },
              "properties": [
                {
                  "id": "color",
                  "value": {
                    "mode": "fixed",
                    "fixedColor": "#FADE2A"
                  }
                },
                {
                  "id": "custom.fillOpacity",
                  "value": 8
                },
                {
                  "id": "custom.fillBelowTo",
                  "value": "tsb_zero"
                },
                {
                  "id": "custom.lineWidth",
                  "value": 2
                },
                {
                  "id": "custom.thresholdsStyle",
                  "value": {
                    "mode": "dashed+area"
                  }
                },
                {
                  "id": "thresholds",
                  "value": {
                    "mode": "absolute",
                    "steps": [
                      {
                        "value": null,
                        "color": "red"
                      },
                      {
                        "value": -30,
                        "color": "orange"
                      },
                      {
                        "value": -10,
                        "color": "transparent"
                      },
                      {
                        "value": 5,
                        "color": "transparent"
                      },
                      {
                        "value": 25,
                        "color": "super-light-blue"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "matcher": {
                "id": "byRegexp",
                "options": ".*projected.*"
              },
              "properties": [
                {
                  "id": "custom.lineStyle",
                  "value": {
                    "fill": "dash",
                    "dash": [
                      10,
                      10
                    ]
                  }
                },
                {
                  "id": "custom.fillOpacity",
                  "value": 3
                },
                {
                  "id": "custom.lineWidth",
                  "value": 1
                }
              ]
            },
            {
              "matcher": {
                "id": "byName",
                "options": "CTL (projected)"
              },
              "properties": [
                {
                  "id": "color",
                  "value": {
                    "mode": "fixed",
                    "fixedColor": "light-blue"
                  }
                }
              ]
            },
            {
              "matcher": {
                "id": "byName",
                "options": "ATL (projected)"
              },
              "properties": [
                {
                  "id": "color",
                  "value": {
                    "mode": "fixed",
                    "fixedColor": "super-light-red"
                  }
                }
              ]
            },
            {
              "matcher": {
                "id": "byName",
                "options": "TSB (projected)"
              },
              "properties": [
                {
                  "id": "color",
                  "value": {
                    "mode": "fixed",
                    "fixedColor": "super-light-yellow"
                  }
                }
              ]
            }
          ]
        },
        "options": {
          "tooltip": {
            "mode": "multi",
            "sort": "none"
          },
          "legend": {
            "displayMode": "table",
            "placement": "bottom",
            "calcs": [
              "lastNotNull",
              "min",
              "max"
            ]
          }
        },
        "links": [
          {
            "title": "View Activities",
            "url": "/d/health-activities/?var-user=$user&${__url_time_range}"
          }
        ]
      },
