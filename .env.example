# Database (TimescaleDB on Home Assistant)
DB_HOST=
DB_PORT=5432
DB_NAME=health
DB_USER=
DB_PASSWORD=

# Garmin Connect (used by garmin-mcp-auth, then OAuth tokens are cached)
GARMIN_EMAIL=
GARMIN_PASSWORD=

# Hevy
HEVY_API_KEY=

# Grafana (on Home Assistant)
GRAFANA_HOST=100.108.0.126
GRAFANA_PORT=18950
GRAFANA_API_KEY=
# DB host as seen from Grafana's container (Docker-internal hostname)
GRAFANA_DB_HOST=77b2833f-timescaledb

# iFit (family account -- IFIT_PROFILE selects which family member)
IFIT_EMAIL=
IFIT_PASSWORD=
IFIT_PROFILE=Alexey

# OpenRouter (AI coaching chat)
OPENROUTER_API_KEY=sk-or-v1-...
CHAT_MODEL=anthropic/claude-sonnet-4
# Generate with: chainlit create-secret
CHAINLIT_AUTH_SECRET=

# Google OAuth (optional -- enables "Sign in with Google" on chat UI)
# Create at: https://console.developers.google.com/apis/credentials
# Callback URL: http://localhost:8080/auth/oauth/google/callback
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

# Apple OAuth (optional -- enables "Sign in with Apple" on chat UI)
# Create at: https://developer.apple.com (Services ID + Sign In key)
OAUTH_APPLE_CLIENT_ID=
OAUTH_APPLE_TEAM_ID=
OAUTH_APPLE_KEY_ID=
# Path to .p8 private key file, or set OAUTH_APPLE_PRIVATE_KEY with PEM contents
OAUTH_APPLE_PRIVATE_KEY_FILE=

# Active user for local dev (scripts operate on this user's data)
USER_SLUG=alexey
USER_FIRST_NAME=Alexey
USER_EMAIL=you@gmail.com
