{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":timezone(Pacific/Auckland)"
  ],
  "schedule": [
    "before 7am on Monday"
  ],
  "labels": [
    "dependencies"
  ],
  "packageRules": [
    {
      "description": "Automerge patch updates",
      "matchUpdateTypes": [
        "patch",
        "pin",
        "digest"
      ],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "description": "Group minor updates into a single PR",
      "matchUpdateTypes": [
        "minor"
      ],
      "groupName": "minor dependencies",
      "groupSlug": "minor-deps"
    },
    {
      "description": "Group major updates per package (manual review)",
      "matchUpdateTypes": [
        "major"
      ],
      "dependencyDashboardApproval": true
    },
    {
      "description": "Pin Docker digests for reproducibility",
      "matchDatasources": [
        "docker"
      ],
      "pinDigests": true
    },
    {
      "description": "Group GitHub Actions updates",
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "github-actions",
      "automerge": true
    }
  ],
  "pip_requirements": {
    "managerFilePatterns": [
      "/requirements\\.txt$/"
    ]
  }
}
